    {"name": "aws_key", "regex": "AKIA[0-9A-Z]{16}"},
    {"name": "github_pat", "regex": "ghp_[A-Za-z0-9]{36}"},
    {"name": "slack_token", "regex": "xox[baprs]-[A-Za-z0-9-]{10,}"},
