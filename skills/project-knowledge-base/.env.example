# Obsidian vault root (absolute path, local machine only)
OBSIDIAN_VAULT_PATH=/Users/username/Documents/Obsidian/Medreclama

# Google OAuth2 credentials (reuse existing OAuth Client from Google Cloud Console)
# Add redirect URI http://localhost:8080/ to the OAuth client in GCP
# `google_token.json` is generated locally after OAuth and must never be committed
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_TOKEN_JSON=./google_token.json
GOOGLE_OAUTH_PORT=8080

# Telegram MTProto — obtain at https://my.telegram.org
# `telegram.session` is generated locally after login and must never be committed
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_FILE=./telegram.session

# moo.team credentials
MOOTEM_BASE_URL=https://api.moo.team/api/v2
MOOTEM_LOGIN=your@email.com
MOOTEM_PASSWORD=yourpassword

# LLM provider selection is mandatory for safety in public/shared setups.
# Allowed values: openai | anthropic
LLM_PROVIDER=openai

# OpenAI API
OPENAI_API_KEY=

# Anthropic API
ANTHROPIC_API_KEY=

# Path to _projects_index.yaml relative to OBSIDIAN_VAULT_PATH
PROJECTS_INDEX_PATH=Агентство/Проекты/_projects_index.yaml

# Optional: local logs directory (auto-created, keep out of VCS)
PKB_LOGS_DIR=./logs
